# ─────────────────────────────────────────────
# Audit Intelligence Platform — Config Template
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# [REQUIRED] Groq API key — get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_api_key_here

# [OPTIONAL] LLM model (default: llama-3.1-8b-instant)
LLM_MODEL=llama-3.1-8b-instant

# [OPTIONAL] Server port (default: 8000)
PORT=8000

# [OPTIONAL] Flask secret key (auto-generated if not set, but set it for production)
SECRET_KEY=change_me_to_a_long_random_string

# [OPTIONAL] Max concurrent engine sessions in memory (default: 10)
MAX_ENGINES=10
